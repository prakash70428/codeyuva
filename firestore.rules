rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /messages/{messageId} {
      // Only allow creating new messages, not reading/updating/deleting
      allow create: if
        // All three fields must be present and be strings
        request.resource.data.name is string &&
        request.resource.data.phone is string &&
        request.resource.data.message is string &&

        // Enforce field length limits to prevent spam/abuse
        request.resource.data.name.size() >= 2 &&
        request.resource.data.name.size() <= 100 &&
        request.resource.data.phone.size() >= 7 &&
        request.resource.data.phone.size() <= 15 &&
        request.resource.data.message.size() >= 10 &&
        request.resource.data.message.size() <= 2000 &&

        // No extra fields allowed beyond the expected schema
        request.resource.data.keys().hasOnly(['name', 'phone', 'message', 'timestamp']);

      // Explicitly deny read, update, and delete for everyone
      allow read, update, delete: if false;
    }

  }
}
